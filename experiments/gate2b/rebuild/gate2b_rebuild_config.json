    "note": "Recovered weight inversion discussed in Opus 4.6 handover notes; connectivity retained as weak prior, not main objective."
  },
  "gate1_gsm": {
    "weights": {
      "lambda2": 0.35,
      "lcc_fraction": 0.20,
      "compactness": 0.20,
      "robustness": 0.15,
      "inverse_hull": 0.10
    }
  }
}
